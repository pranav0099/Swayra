<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <!-- Countdown header. Tapping it opens the app. -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEXT UP"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="#FF5C00" />

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Exam"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#191C1D"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="30sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:textColor="#191C1D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="d"
                android:textSize="14sp"
                android:textColor="#5F5E5E"
                android:layout_marginBottom="2dp"
                android:layout_marginStart="2dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E4BEB1"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="7dp" />

    <TextView
        android:id="@+id/widget_habits_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TODAY"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="#9A9A9A"
        android:layout_marginBottom="4dp" />

    <!-- Up to three of today's habits; each row toggles without opening the app. -->
    <LinearLayout
        android:id="@+id/habit_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/habit_check_0"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:text="○"
            android:textSize="13sp"
            android:textColor="#9A9A9A" />

        <TextView
            android:id="@+id/habit_name_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#33373A" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/habit_check_1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:text="○"
            android:textSize="13sp"
            android:textColor="#9A9A9A" />

        <TextView
            android:id="@+id/habit_name_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#33373A" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/habit_check_2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:text="○"
            android:textSize="13sp"
            android:textColor="#9A9A9A" />

        <TextView
            android:id="@+id/habit_name_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#33373A" />
    </LinearLayout>

    <!-- Shown instead of the rows when nothing is due today. -->
    <TextView
        android:id="@+id/habit_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No rituals due today"
        android:textSize="11sp"
        android:textColor="#9A9A9A"
        android:visibility="gone" />
</LinearLayout>
